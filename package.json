{
  "name": "ts-node-template",
  "version": "1.0.0",
  "packageManager": "npm@11.18.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "npm install --include=dev && npx tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "watch": "tsc -w",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx --env-file=.env src/db/seedScript.ts",
    "db:gen-mig": "drizzle-kit generate && drizzle-kit migrate",
    "test": "vitest run --config src/configs/vitest.config.ts",
    "test:watch": "vitest --config src/configs/vitest.config.ts",
    "test:coverage": "vitest run --coverage --config src/configs/vitest.config.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaxKolbe/ts-node-template.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/MaxKolbe/ts-node-template/issues"
  },
  "homepage": "https://github.com/MaxKolbe/ts-node-template#readme",
  "dependencies": {
    "@bull-board/api": "^7.0.0",
    "@bull-board/express": "^7.0.0",
    "@getbrevo/brevo": "^5.0.4",
    "@logtail/node": "^0.5.8",
    "@logtail/winston": "^0.5.8",
    "@zayne-labs/callapi": "^1.13.0",
    "bcryptjs": "3.0.3",
    "bullmq": "5.76.6",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "2.8.6",
    "drizzle-kit": "0.31.10",
    "drizzle-orm": "0.45.2",
    "ejs": "^5.0.2",
    "express": "5.2.1",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "9.0.3",
    "multer": "^2.1.1",
    "node-schedule": "^2.1.1",
    "pg": "8.20.0",
    "rate-limit-redis": "^5.0.0",
    "redis": "5.12.1",
    "tsx": "4.21.0",
    "winston": "3.19.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.19",
    "@types/ejs": "^3.1.5",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "25.6.2",
    "@types/node-schedule": "^2.1.8",
    "@types/pg": "8.20.0",
    "@types/supertest": "^7.2.1",
    "supertest": "^7.2.2",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  }
}
